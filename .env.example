# ============================================================
#  GUARDIANS TOKEN (GOTT) — Environment Config
# ============================================================
#  ⚠️  JANGAN COMMIT FILE INI KE GITHUB!
#  Tambahkan .env ke .gitignore
# ============================================================

# Private key wallet deployer (tanpa 0x prefix juga bisa)
PRIVATE_KEY=your_private_key_here

# BscScan API key untuk verifikasi contract
# Daftar gratis di: https://bscscan.com/myapikey
BSCSCAN_API_KEY=your_bscscan_api_key_here
